# Supabase — copia este archivo a .env.local y llena con las keys de tu proyecto.
# Dashboard de Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NO commitear .env.local. El service_role key NUNCA debe ir al cliente.
# Si necesitas operaciones server-only en el futuro, agrega:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
